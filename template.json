{
  "messages": {
    "ackReactionScope": "group-mentions"
  },
  "agents": {
    "defaults": {
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      },
      "compaction": {
        "mode": "safeguard"
      },
      "workspace": "/home/node/.openclaw/workspace",
      "model": {
        "primary": "blockeden/claude-sonnet-4-5-20250929"
      },
      "models": {
        "blockeden/claude-sonnet-4-5-20250929": {}
      }
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "blockeden": {
        "baseUrl": "${ANTHROPIC_BASE_URL}",
        "apiKey": "placeholder",
        "api": "anthropic-messages",
        "models": [
          {
            "id": "claude-sonnet-4-5-20250929",
            "name": "claude-sonnet-4-5-20250929",
            "input": ["text", "image"],
            "contextWindow": 200000,
            "maxTokens": 4096
          }
        ]
      }
    }
  },
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "controlUi": {
      "allowedOrigins": ["${OPENCLAW_GATEWAY_CONTROL_UI_ALLOWED_ORIGINS}"]
    },
    "port": 18789,
    "bind": "loopback",
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    }
  },
  "auth": {
    "profiles": {
      "anthropic:default": {
        "provider": "anthropic",
        "mode": "token"
      }
    }
  },
  "plugins": {
    "entries": {
      "telegram": {
        "enabled": true
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "open",
      "allowFrom": ["*"]
    }
  },
  "skills": {
    "install": {
      "nodeManager": "npm"
    }
  }
}
